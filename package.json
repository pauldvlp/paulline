{
  "name": "paulline",
  "version": "0.1.0",
  "private": true,
  "description": "Centralized panel to orchestrate Cloudflare tunnels from multiple remote machines.",
  "license": "MIT",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @paulline/web test:e2e",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "db:generate": "pnpm --filter @paulline/database db:generate",
    "db:push": "pnpm --filter @paulline/database db:push"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
