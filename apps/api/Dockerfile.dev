# Development image for the NestJS api. Source is bind-mounted at runtime so
# `nest start --watch` rebuilds on change; node_modules stays image-internal.
FROM node:22-slim

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

# procps provides `ps`, which the Nest CLI watch mode uses to restart the app.
RUN apt-get update \
  && apt-get install -y --no-install-recommends procps \
  && rm -rf /var/lib/apt/lists/*

RUN corepack enable

WORKDIR /app

# Install workspace dependencies using the lockfile for reproducible builds.
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.base.json ./
COPY packages ./packages
COPY apps/api ./apps/api
RUN pnpm install --frozen-lockfile --config.strict-dep-builds=false \
  && pnpm rebuild @prisma/client @prisma/engines prisma

# Generate the Prisma client and build workspace packages so the api resolves
# @paulline/* from their compiled dist output.
RUN pnpm --filter @paulline/database db:generate \
  && pnpm --filter @paulline/schemas --filter @paulline/types --filter @paulline/database build

EXPOSE 3000

CMD ["pnpm", "--filter", "@paulline/api", "start:dev"]
